{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A creative development project in the portfolio.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "year": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "github": { "type": "string" },
        "live": { "type": "string" }
      },
      "required": ["id", "title", "category", "year", "description"]
    },
    "VisitorMessage": {
      "title": "VisitorMessage",
      "description": "Real-time client impression notes left on the portfolio.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "message", "createdAt"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Dynamic layout metadata for selected design works."
    },
    "visitor_messages": {
      "schema": "VisitorMessage",
      "description": "Real-time messages submitted by visitors."
    }
  }
}
